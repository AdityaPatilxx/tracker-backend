# ─── TCP Server ───────────────────────────────────────────────────────────────
# Port that Active Reader devices connect to
TCP_PORT=4600
# Host IP returned to devices after registration (your server's LAN IP)
SERVER_HOST=127.0.0.1

# ─── HTTP / WebSocket API ─────────────────────────────────────────────────────
API_PORT=8080

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=active_reader
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10

# ─── Logging ──────────────────────────────────────────────────────────────────
# 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=debug
# 'true' for pretty-printed local dev, 'false' for JSON in production
LOG_PRETTY=true

# ─── Device Timeouts ──────────────────────────────────────────────────────────
# How long (ms) before a device with no heartbeat is marked stale
HEARTBEAT_TIMEOUT_MS=120000
# How often (ms) the watchdog checks for stale devices
WATCHDOG_INTERVAL_MS=30000
